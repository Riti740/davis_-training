        "def login():\n",
        "    correct_user = \"admin\"\n",
        "    correct_pass = \"1234\"\n",
        "\n",
        "    attempts = 0\n",
        "    while attempts < 3:\n",
        "        u = input(\"Enter username: \")\n",
        "        p = input(\"Enter password: \")\n",
        "\n",
        "        if u == correct_user and p == correct_pass:\n",
        "            print(\"Login Successful\")\n",
        "            return\n",
        "        else:\n",
        "            print(\"Wrong credentials\")\n",
        "            attempts += 1\n",
        "\n",
        "    print(\"Account Locked\")\n",
        "\n",
        "login()"
