        "def classify(num):\n",
        "    if num > 0:\n",
        "        print(\"Positive\", end=\", \")\n",
        "    elif num < 0:\n",
        "        print(\"Negative\", end=\", \")\n",
        "    else:\n",
        "        print(\"Zero\", end=\", \")\n",
        "\n",
        "    if num != 0:\n",
        "        if num % 2 == 0:\n",
        "            print(\"Even\")\n",
        "        else:\n",
        "            print(\"Odd\")\n",
        "    else:\n",
        "        print()\n",
        "\n",
        "nums = [10, -5, 0, 7, -2]\n",
        "\n",
        "for n in nums:\n",
        "    print(n, \"->\", end=\" \")\n",
        "    classify(n)"
      ]
