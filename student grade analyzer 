        "def calculate_grade(marks):\n",
        "    if marks >= 90:\n",
        "        return \"A\"\n",
        "    elif marks >= 75:\n",
        "        return \"B\"\n",
        "    elif marks >= 50:\n",
        "        return \"C\"\n",
        "    else:\n",
        "        return \"Fail\"\n",
        "\n",
        "for i in range(5):\n",
        "    m = int(input(f\"Enter marks of student {i+1}: \"))\n",
        "    print(\"Grade:\", calculate_grade(m))"
      ]
